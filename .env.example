# ─────────────────────────────────────────────
# HederaToolbox
# ─────────────────────────────────────────────

# Your Hedera account ID — this IS your Toolbox API key.
# Top up at https://hederatoolbox.com (send any HBAR to 0.0.10309126, no memo).
# Credits appear within ~10 seconds.
TOOLBOX_API_KEY=0.0.XXXXXXX

# Toolbox MCP endpoint — do not change.
TOOLBOX_API_URL=https://api.hederatoolbox.com

# ─────────────────────────────────────────────
# Fixatum DID (optional — add later via: npm run register)
# ─────────────────────────────────────────────

# Your Fixatum DID — issued after sending 100 HBAR to Fixatum.
# Leave blank until registered. The agent runs fine without it.
# Full instructions: https://fixatum.com/register
AGENT_DID=

# Your agent's Hedera account ID (same as TOOLBOX_API_KEY in most cases).
AGENT_ACCOUNT_ID=0.0.XXXXXXX

# Your dedicated HCS topic ID — assigned automatically at Fixatum registration.
# Required for hcs_write_record. Leave blank until registered.
AGENT_HCS_TOPIC=

# ─────────────────────────────────────────────
# Agent identity (used in HCS records and logs)
# ─────────────────────────────────────────────

# Short human-readable name for your agent.
AGENT_LABEL=my-agent
